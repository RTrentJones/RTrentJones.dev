---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostCard from '../components/PostCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<Base>
  <section class="intro">
    {/* TODO: make this intro yours — a sentence or two about who you are + what you're into. */}
    <h1>Trent Jones</h1>
    <p class="lede">
      Engineer building self-verifying tools — every change ships through an objective gate. Below are
      the projects I run live, and notes on building them.
    </p>
  </section>

  <section id="projects">
    <h2>Projects</h2>
    <div class="grid">
      {
        projects.map((p) => (
          <ProjectCard
            href={`/${p.id}/`}
            title={p.data.title}
            summary={p.data.summary}
            liveUrl={p.data.liveUrl}
            status={p.data.status}
          />
        ))
      }
    </div>
  </section>

  <section class="recent">
    <h2>Recent writing</h2>
    <div class="post-list">
      {
        posts.map((post) => (
          <PostCard
            href={`/blog/${post.id}/`}
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
          />
        ))
      }
    </div>
    <p class="more"><a href="/blog/">All posts →</a></p>
  </section>
</Base>

<style>
  .intro {
    margin: 1.5rem 0 3rem;
  }
  .intro h1 {
    margin-bottom: 0.6rem;
  }
  .lede {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    max-width: var(--measure);
  }
  section + section {
    margin-top: 3rem;
  }
  h2 {
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .post-list {
    display: grid;
    gap: 1.5rem;
  }
  .more {
    margin-top: 1.5rem;
  }
</style>
