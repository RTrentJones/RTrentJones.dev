---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Base>
  <section class="intro">
    {/* TODO: make this intro yours — a sentence or two about who you are + what you're into. */}
    <h1>Trent Jones</h1>
    <p class="lede">
      Engineer building self-verifying tools — every change ships through an objective gate. I write
      about building them here; the things I run live are under <a href="/projects/">projects</a>.
    </p>
  </section>

  <section class="recent">
    <h2>Writing</h2>
    <div class="post-list">
      {
        posts.map((post) => (
          <PostCard
            href={`/blog/${post.id}/`}
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
          />
        ))
      }
    </div>
    <p class="more"><a href="/blog/">All posts →</a></p>
  </section>
</Base>

<style>
  .intro {
    margin: 1.5rem 0 3rem;
  }
  .intro h1 {
    margin-bottom: 0.6rem;
  }
  .lede {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    max-width: var(--measure);
  }
  .recent h2 {
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .post-list {
    display: grid;
    gap: 1.5rem;
  }
  .more {
    margin-top: 1.5rem;
  }
</style>
