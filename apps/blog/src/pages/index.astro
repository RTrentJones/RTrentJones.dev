---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
// An `external: true` project links straight to its repo instead of a local write-up; none are
// external today, so every card resolves to /<slug>/.
const projectHref = (p: (typeof projects)[number]) =>
  p.data.external ? (p.data.repoUrl ?? '#') : `/${p.id}/`;
---

<Base>
  <section class="intro">
    <h1>Trent Jones</h1>
    <p class="lede">
      I build products — and the platforms and tooling that make building them faster. This site is
      the other half: the stuff I chase on my own time — LLM-driven development, the life sciences,
      engineering for its own sake — some sparked by the day job, some just mine.
    </p>
  </section>

  <div class="home">
    <div class="writing">
      <h2>Writing</h2>
      <div class="post-list">
        {
          posts.map((post) => (
            <PostCard
              href={`/blog/${post.id}/`}
              title={post.data.title}
              date={post.data.date}
              description={post.data.description}
            />
          ))
        }
      </div>
      <p class="more"><a href="/blog/">All posts →</a></p>
    </div>

    <aside class="sidebar">
      <section class="panel">
        <h2>About</h2>
        <p>
          Senior engineer at Amazon, 11 years in. Dual degrees in neuroscience and CS at USC — the
          life-sciences thread still runs through what I build.
        </p>
        <p class="more"><a href="/about/">More about me →</a></p>
      </section>

      <section class="panel">
        <h2>Projects</h2>
        <ul class="project-links">
          {
            projects.map((p) => (
              <li>
                <a href={projectHref(p)}>
                  {p.data.title}
                  {p.data.external && <span class="ext">↗</span>}
                </a>
                <span class="blurb">{p.data.summary}</span>
              </li>
            ))
          }
        </ul>
        <p class="more"><a href="/projects/">All projects →</a></p>
      </section>
    </aside>
  </div>
</Base>

<style>
  .intro {
    margin: 1.5rem 0 2.75rem;
  }
  .intro h1 {
    margin-bottom: 0.6rem;
  }
  .lede {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    max-width: var(--measure);
  }

  /* Single column by default (writing first, then the sidebar stacks below it). */
  .home {
    display: grid;
    gap: 3rem;
  }
  /* Two columns when there's room: writing on the left, about + projects on the right. */
  @media (min-width: 860px) {
    .home {
      grid-template-columns: minmax(0, 1fr) 15rem;
      gap: 3.5rem;
      align-items: start;
    }
  }

  .writing > h2 {
    margin-top: 0;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .post-list {
    display: grid;
    gap: 1.5rem;
  }
  .more {
    margin-top: 1.25rem;
    font-size: 0.95rem;
  }

  .sidebar {
    display: grid;
    gap: 2.5rem;
    align-content: start;
  }
  .panel h2 {
    margin-top: 0;
    font-size: var(--text-base);
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--border);
  }
  .panel p {
    color: var(--fg-muted);
    font-size: 0.95rem;
  }
  .panel .more {
    margin-top: 0.9rem;
  }
  .project-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .project-links a {
    font-weight: 600;
    color: var(--fg);
    text-decoration: none;
  }
  .project-links a:hover {
    color: var(--accent);
  }
  .ext {
    color: var(--fg-muted);
    font-size: 0.8rem;
    margin-left: 0.2rem;
  }
  .blurb {
    display: block;
    color: var(--fg-muted);
    font-size: 0.85rem;
    line-height: 1.45;
    margin-top: 0.15rem;
  }
</style>
