---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { registeredTools } from '../data/manifest';

// Draft homepage. Kept at /v2 (noindex) so it can be compared against the current / before promoting.
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
const featured = projects.filter((p) => p.data.featured);

// Evidence strip — straight from the manifest, so it can't drift from what's actually deployed.
const providerCount = new Set(registeredTools.flatMap((t) => t.providers)).size;

const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Trent Jones',
  url: 'https://rtrentjones.dev/',
  jobTitle: 'Senior Software Development Engineer',
  worksFor: { '@type': 'Organization', name: 'Amazon' },
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'University of Southern California' },
  sameAs: ['https://github.com/RTrentJones', 'https://www.linkedin.com/in/rtrentjones'],
};
---

<Base
  description="Trent Jones — senior engineer building self-verifying infrastructure, agentic workflows, and life-sciences tooling."
  structuredData={person}
  noindex
>
  <p class="draft-note">Draft homepage — compare with <a href="/">the current home</a>.</p>

  <section class="hero">
    <h1>Trent Jones</h1>
    <p class="lede">
      Senior engineer at Amazon building <strong>self-verifying infrastructure</strong> — resilient
      systems, agentic workflows, and tools that publish the evidence that they work. This site is
      one of them.
    </p>
    <ul class="stats">
      <li><strong>{projects.length}</strong><span>showcased projects</span></li>
      <li><strong>{registeredTools.length}</strong><span>deployed tools</span></li>
      <li><strong>{providerCount}</strong><span>cloud providers</span></li>
    </ul>
    <p class="stat-note">
      Deployed inventory and providers are generated from the Greenlight manifest — see the
      <a href="/projects/">full registry</a>.
    </p>
  </section>

  <section class="block selected">
    <h2>Selected systems</h2>
    <div class="grid">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
    <p class="more"><a href="/projects/">All projects →</a></p>
  </section>

  <section class="block writing">
    <h2>Writing</h2>
    <div class="post-list">
      {
        posts.map((post) => (
          <PostCard
            href={`/blog/${post.id}/`}
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
          />
        ))
      }
    </div>
    <p class="more"><a href="/blog/">All posts →</a></p>
  </section>

  <section class="block contact">
    <h2>Contact</h2>
    <p>
      <a href="/about/">More about me</a>, or reach me on
      <a href="https://github.com/RTrentJones">GitHub</a> and
      <a href="https://www.linkedin.com/in/rtrentjones">LinkedIn</a>.
    </p>
  </section>
</Base>

<style>
  .draft-note {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    border: 1px dashed var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.8rem;
    margin: 1rem 0 2rem;
  }
  .hero {
    margin: 1rem 0 0;
  }
  .hero h1 {
    margin-bottom: 0.6rem;
  }
  .lede {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    max-width: var(--measure);
  }
  .stats {
    list-style: none;
    margin: 1.75rem 0 0.7rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2.5rem;
  }
  .stats li {
    display: flex;
    flex-direction: column;
  }
  .stats strong {
    font-size: var(--text-2xl);
    font-weight: 650;
    line-height: 1;
    color: var(--fg);
  }
  .stats span {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    margin-top: 0.25rem;
  }
  .stat-note {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    max-width: var(--measure);
  }
  .block {
    margin-top: 3rem;
  }
  .block > h2 {
    margin-top: 0;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .post-list {
    display: grid;
    gap: 1.5rem;
  }
  .more {
    margin-top: 1.25rem;
    font-size: 0.95rem;
  }
</style>
