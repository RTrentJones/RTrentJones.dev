---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { envFromSite, isMcpServer, toolByName, toolUrl } from '../data/manifest';

// Top-level write-up pages (/heistmind, /bamcp). Astro's SSG emits ONLY the slugs returned
// here, so this never shadows the static routes (/, /blog, /about).
export async function getStaticPaths() {
  // A local project whose slug equals one of these would generate a route shadowing a static page.
  // (Defined inside getStaticPaths — Astro extracts this function and won't capture outer consts.)
  const RESERVED = new Set(['about', 'blog', 'projects', 'rss', 'sitemap', '404']);
  const projects = await getCollection('projects');
  // An external: true project links straight to GitHub — no local write-up page. (None today.)
  const local = projects.filter((project) => !project.data.external);
  const collision = local.find((p) => RESERVED.has(p.id));
  if (collision) {
    throw new Error(
      `project slug "${collision.id}" collides with a static route (${[...RESERVED].join(', ')}) — rename the file or set external: true`,
    );
  }
  return local.map((project) => ({ params: { project: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, liveUrl, repoUrl, status, evidenceUrl } = project.data;
// Deployed tools get an env-aware live URL from the manifest (a beta write-up links to the beta
// tool); non-tools fall back to the MDX liveUrl.
const facets = toolByName[project.id];
// Prefer an explicit MDX liveUrl (e.g. heistmind points at its beta app, since prod is gated) over the
// manifest's env-aware URL.
const live = liveUrl ?? (facets ? toolUrl(project.id, envFromSite(Astro.site)) : undefined);
// MCP servers aren't browsable — the "live" surface is an OAuth-gated /mcp endpoint that 401s in a
// browser — so send the CTA to the on-page setup section instead. Otherwise label it to match
// status. Browsable mcp-lane apps (polyphony) get the normal live CTA.
const isMcp = isMcpServer(project.id);
const openLabel =
  status === 'prototype'
    ? 'Open the prototype ↗'
    : status === 'beta'
      ? 'Open the beta ↗'
      : 'Open the live tool ↗';
---

<Base title={title} description={summary} prose>
  <article>
    <p class="back"><a href="/projects">← projects</a></p>
    <h1>{title}</h1>
    <p class="summary">{summary}</p>
    <p class="links">
      {isMcp ? (
        <a class="cta" href="#connect-it-to-claude">Connect to Claude ↓</a>
      ) : (
        live && <a class="cta" href={live}>{openLabel}</a>
      )}
      {repoUrl && <a href={repoUrl}>Source ↗</a>}
      {status &&
        (evidenceUrl ? (
          <a class="muted" href={evidenceUrl}>
            {status} ↗
          </a>
        ) : (
          <span class="muted">{status}</span>
        ))}
    </p>
    <Content />
  </article>
</Base>

<style>
  .back {
    margin-bottom: 1.5rem;
  }
  .summary {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    margin-bottom: 0.8rem;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .cta {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    background: var(--accent);
    color: var(--accent-fg);
    border-radius: 7px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .cta:hover {
    text-decoration: none;
    filter: brightness(1.05);
  }
</style>
