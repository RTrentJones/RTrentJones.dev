---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { envFromSite, toolByName, toolUrl } from '../data/manifest';

// Top-level write-up pages (/heistmind, /bamcp). Astro's SSG emits ONLY the slugs returned
// here, so this never shadows the static routes (/, /blog, /about).
export async function getStaticPaths() {
  // A local project whose slug equals one of these would generate a route shadowing a static page.
  // (Defined inside getStaticPaths — Astro extracts this function and won't capture outer consts.)
  const RESERVED = new Set(['about', 'blog', 'projects', 'rss', 'sitemap', '404']);
  const projects = await getCollection('projects');
  // External projects (e.g. Greenlight) link straight to GitHub — no local write-up page.
  const local = projects.filter((project) => !project.data.external);
  const collision = local.find((p) => RESERVED.has(p.id));
  if (collision) {
    throw new Error(
      `project slug "${collision.id}" collides with a static route (${[...RESERVED].join(', ')}) — rename the file or set external: true`,
    );
  }
  return local.map((project) => ({ params: { project: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, liveUrl, repoUrl, status } = project.data;
// Deployed tools get an env-aware live URL from the manifest (a beta write-up links to the beta
// tool); non-tools fall back to the MDX liveUrl.
const facets = toolByName[project.id];
const live = facets ? toolUrl(project.id, envFromSite(Astro.site)) : liveUrl;
---

<Base title={title} description={summary} prose>
  <article>
    <p class="back"><a href="/#projects">← projects</a></p>
    <h1>{title}</h1>
    <p class="summary">{summary}</p>
    <p class="links">
      {live && <a class="cta" href={live}>Open the live tool ↗</a>}
      {repoUrl && <a href={repoUrl}>Source ↗</a>}
      {status && <span class="muted">{status}</span>}
    </p>
    <Content />
  </article>
</Base>

<style>
  .back {
    margin-bottom: 1.5rem;
  }
  .summary {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    margin-bottom: 0.8rem;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .cta {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    background: var(--accent);
    color: var(--accent-fg);
    border-radius: 7px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .cta:hover {
    text-decoration: none;
    filter: brightness(1.05);
  }
</style>
