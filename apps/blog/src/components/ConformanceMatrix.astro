---
// The "live demo": a green/red/na grid of unmodified Kafka clients × the 23 implemented Kafka
// APIs, generated by CI and rendered server-side (no client JS). Data + seed fallback come from
// ../lib/evidence.
import { loadConformance, fmtVerified, type CellStatus } from '../lib/evidence';

const { data, source } = await loadConformance();
const { apis, clients, generatedAt, gitSha } = data;

// Coverage = pass / (pass + fail); `na` (client doesn't exercise that API) is excluded.
let passed = 0;
let attempted = 0;
for (const c of clients) {
  for (const a of apis) {
    const s = c.results[a.name];
    if (s === 'pass') {
      passed++;
      attempted++;
    } else if (s === 'fail') {
      attempted++;
    }
  }
}
const coverage = attempted ? Math.round((passed / attempted) * 100) : 0;
const glyph: Record<CellStatus, string> = { pass: '✓', fail: '✕', na: '–' };
---

<figure class="conformance">
  <figcaption>
    <strong>Client compatibility × Kafka API coverage</strong>
    <span class="meta">
      {clients.length} clients · {apis.length} APIs · {coverage}% pass · verified {
        fmtVerified(generatedAt)
      } UTC{gitSha && gitSha !== '0000000' ? ` · ${gitSha.slice(0, 7)}` : ''}
      {source === 'seed' && <span class="seed">seed — awaiting first CI run</span>}
    </span>
  </figcaption>

  <div class="scroll">
    <table>
      <thead>
        <tr>
          <th class="rowhead">Client</th>
          {apis.map((a) => (
            <th class="apihead" title={`API key ${a.key}`}><span>{a.name}</span></th>
          ))}
        </tr>
      </thead>
      <tbody>
        {clients.map((c) => (
          <tr>
            <th class="rowhead" scope="row">
              {c.name}
              <span class="lang">{c.lang}</span>
            </th>
            {apis.map((a) => {
              const s = (c.results[a.name] ?? 'na') as CellStatus;
              return (
                <td class:list={['cell', s]} title={`${c.name} · ${a.name}: ${s}`}>
                  <span class="sr">{s}</span>
                  <span aria-hidden="true">{glyph[s]}</span>
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p class="legend">
    <span class="cell pass" aria-hidden="true">✓</span> pass
    <span class="cell fail" aria-hidden="true">✕</span> fail
    <span class="cell na" aria-hidden="true">–</span> n/a (client doesn't exercise this API)
  </p>
</figure>

<style>
  .conformance {
    margin: 1.6rem 0 2.2rem;
  }
  figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 0.7rem;
  }
  figcaption strong {
    font-size: var(--text-base);
  }
  .meta {
    font-size: var(--text-sm);
    color: var(--fg-muted);
  }
  .seed {
    margin-left: 0.5rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.66rem;
  }
  .scroll {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 10px;
  }
  table {
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  thead .apihead {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    text-align: left;
    vertical-align: bottom;
    padding: 0.5rem 0.15rem;
    font-weight: 600;
    color: var(--fg-muted);
    white-space: nowrap;
  }
  .apihead span {
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
  .rowhead {
    text-align: left;
    padding: 0.45rem 0.85rem 0.45rem 0.7rem;
    white-space: nowrap;
    font-weight: 650;
    position: sticky;
    left: 0;
    background: var(--bg-subtle);
    border-right: 1px solid var(--border);
  }
  thead .rowhead {
    vertical-align: bottom;
  }
  .lang {
    display: block;
    font-weight: 400;
    font-size: 0.68rem;
    color: var(--fg-muted);
    font-family: var(--font-mono);
  }
  .cell {
    text-align: center;
    width: 1.7rem;
    padding: 0.4rem 0;
    border-left: 1px solid var(--border);
    border-top: 1px solid var(--border);
    font-weight: 700;
  }
  tbody tr:first-child .cell {
    border-top: none;
  }
  .cell.pass {
    color: #1f7a4d;
    background: rgba(31, 122, 77, 0.12);
  }
  .cell.fail {
    color: #c0392b;
    background: rgba(192, 57, 43, 0.14);
  }
  .cell.na {
    color: var(--fg-muted);
    opacity: 0.6;
  }
  .legend {
    margin-top: 0.7rem;
    font-size: var(--text-sm);
    color: var(--fg-muted);
  }
  .legend .cell {
    display: inline-block;
    width: auto;
    border: none;
    padding: 0 0.15rem 0 0.6rem;
    background: none;
  }
  .sr {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }
  @media (prefers-color-scheme: dark) {
    .cell.pass {
      color: #4ade80;
      background: rgba(74, 222, 128, 0.14);
    }
    .cell.fail {
      color: #f87171;
      background: rgba(248, 113, 113, 0.16);
    }
  }
</style>
