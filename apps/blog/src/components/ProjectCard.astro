---
import type { CollectionEntry } from 'astro:content';
import {
  envFromSite,
  isMcpServer,
  providersFor,
  stackLine,
  toolByName,
  toolUrl,
} from '../data/manifest';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { title, summary, liveUrl, repoUrl, status, external, evidenceUrl, verifyMode } = project.data;

// Live details from the manifest (single source of truth) when this project is a deployed tool — its
// stack, providers, and an env-aware live URL. An explicit MDX liveUrl wins (e.g. heistmind points at
// its beta app, since prod is gated); non-tools fall back to it too.
const facets = toolByName[project.id];
const providers = facets ? providersFor(facets) : [];
const live = liveUrl ?? (facets ? toolUrl(project.id, envFromSite(Astro.site)) : undefined);
// MCP servers aren't browsable (the /mcp endpoint 401s), so skip the "Live ↗" link on the card — the
// write-up carries the "Connect to Claude" setup. Browsable mcp-lane apps (polyphony) are exempt.
const isMcp = isMcpServer(project.id);

// Local projects get a write-up page at /<slug>/; an external: true project links straight out
// instead (none are external today).
const writeup = external ? undefined : `/${project.id}/`;
const primary = writeup ?? repoUrl ?? live ?? '#';

// Anchor the status badge to evidence: link it to evidenceUrl when present, and name the verify
// mode that backs it — so "verified" points at proof rather than just asserting.
const statusTitle = verifyMode ? `${status} · backed by ${verifyMode} verify` : status;
---

<article class="project-card">
  <h3>
    <a href={primary}>{title}</a>
    {status &&
      (evidenceUrl ? (
        <a class="status" data-status={status} href={evidenceUrl} title={statusTitle}>
          {status}
        </a>
      ) : (
        <span class="status" data-status={status} title={statusTitle}>
          {status}
        </span>
      ))}
  </h3>
  {facets && <p class="stack">{stackLine(facets)}</p>}
  <p class="summary">{summary}</p>
  {
    providers.length > 0 && (
      <ul class="providers" aria-label="Providers">
        {providers.map((p) => (
          <li>{p}</li>
        ))}
      </ul>
    )
  }
  <p class="links">
    {writeup && <a href={writeup}>Write-up →</a>}
    {live && !isMcp && <a href={live}>Live ↗</a>}
    {!writeup && repoUrl && <a href={repoUrl}>GitHub ↗</a>}
  </p>
</article>

<style>
  .project-card {
    padding: 1.2rem 1.3rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-subtle);
    display: flex;
    flex-direction: column;
  }
  .project-card h3 {
    margin: 0 0 0.2rem;
    font-size: var(--text-lg);
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .project-card h3 a {
    color: var(--fg);
    text-decoration: none;
  }
  .project-card h3 a:hover {
    color: var(--accent);
  }
  .status {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--fg-muted);
    text-decoration: none;
  }
  /* verified / published / live read as "proven"; prototype / experimental as "partial"; the rest stay muted. */
  .status[data-status='verified'],
  .status[data-status='published'],
  .status[data-status='live'] {
    color: var(--accent);
  }
  .status[data-status='beta'],
  .status[data-status='prototype'],
  .status[data-status='experimental'] {
    color: var(--warn);
  }
  a.status {
    border-bottom: 1px dashed currentColor;
  }
  a.status:hover {
    color: var(--accent);
  }
  .stack {
    margin: 0 0 0.5rem !important;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--fg-muted);
    text-transform: lowercase;
  }
  .summary {
    margin: 0 0 0.7rem;
    color: var(--fg-muted);
  }
  .providers {
    list-style: none;
    margin: 0 0 0.9rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .providers li {
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.12rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--fg-muted);
  }
  .links {
    display: flex;
    gap: 1.1rem;
    font-size: 0.95rem;
    margin: auto 0 0 !important;
    padding-top: 0.2rem;
  }
</style>
