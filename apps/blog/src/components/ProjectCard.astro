---
import type { CollectionEntry } from 'astro:content';
import { envFromSite, providersFor, stackLine, toolByName, toolUrl } from '../data/manifest';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { title, summary, liveUrl, repoUrl, status, external } = project.data;

// Live details from the manifest (single source of truth) when this project is a deployed tool — its
// stack, providers, and an env-aware live URL (a beta card links to the beta tool). Non-tools (e.g.
// the framework) fall back to the MDX liveUrl.
const facets = toolByName[project.id];
const providers = facets ? providersFor(facets) : [];
const live = facets ? toolUrl(project.id, envFromSite(Astro.site)) : liveUrl;

// Local projects get a write-up page at /<slug>/; external ones (e.g. Greenlight) link straight out.
const writeup = external ? undefined : `/${project.id}/`;
const primary = writeup ?? repoUrl ?? live ?? '#';
---

<article class="project-card">
  <h3>
    <a href={primary}>{title}</a>
    {status && <span class="status">{status}</span>}
  </h3>
  {facets && <p class="stack">{stackLine(facets)}</p>}
  <p class="summary">{summary}</p>
  {
    providers.length > 0 && (
      <ul class="providers" aria-label="Providers">
        {providers.map((p) => (
          <li>{p}</li>
        ))}
      </ul>
    )
  }
  <p class="links">
    {writeup && <a href={writeup}>Write-up →</a>}
    {live && <a href={live}>Live ↗</a>}
    {!writeup && repoUrl && <a href={repoUrl}>GitHub ↗</a>}
  </p>
</article>

<style>
  .project-card {
    padding: 1.2rem 1.3rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-subtle);
    display: flex;
    flex-direction: column;
  }
  .project-card h3 {
    margin: 0 0 0.2rem;
    font-size: var(--text-lg);
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .project-card h3 a {
    color: var(--fg);
    text-decoration: none;
  }
  .project-card h3 a:hover {
    color: var(--accent);
  }
  .status {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .stack {
    margin: 0 0 0.5rem !important;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--fg-muted);
    text-transform: lowercase;
  }
  .summary {
    margin: 0 0 0.7rem;
    color: var(--fg-muted);
  }
  .providers {
    list-style: none;
    margin: 0 0 0.9rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .providers li {
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.12rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--fg-muted);
  }
  .links {
    display: flex;
    gap: 1.1rem;
    font-size: 0.95rem;
    margin: auto 0 0 !important;
    padding-top: 0.2rem;
  }
</style>
