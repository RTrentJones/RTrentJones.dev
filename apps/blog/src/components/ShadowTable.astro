---
// Shadow-mode forwarding compliance: pg_kafka can dual-write to an external Kafka cluster (migration /
// validation / hybrid). This renders shadow.json — one pass/fail row per forwarding scenario plus a
// parity block for the headline 100% dual-write topic — generated by CI on the SAME evidence run as the
// conformance grid and benchmark. Its point is before/after stability: the numbers are identical whether
// or not the dead pre-outbox producer is present, so the table is objective proof the live outbox path
// is what does the forwarding. Server-side, no client JS; evidence branch is the single source of truth,
// no fabricated fallback. Status-glyph styling mirrors ConformanceMatrix; scaffolding mirrors BenchTable.
import { loadShadow, fmtVerified, REPO_URL, type CellStatus } from '../lib/evidence';

const { data } = await loadShadow();
const n = (x: number) => x.toLocaleString('en-US');
const glyph: Record<CellStatus, string> = { pass: '✓', fail: '✕', na: '–' };

// Human-readable scenario labels (fall back to the raw key for any future scenario).
const LABELS: Record<string, string> = {
  dual_write_sync: 'Dual-write · sync — full parity',
  dual_write_async: 'Dual-write · async — full parity',
  external_only: 'External-only — forward without local dual-write',
  percentage_50: 'Sampled forwarding — 50% of records',
  committed_txn_forwarded: 'Committed transaction — forwarded on commit',
  aborted_txn_not_forwarded: 'Aborted transaction — never forwarded',
};
const label = (key: string) => LABELS[key] ?? key;
---

{
  !data ? (
    <p class="evidence-pending">
      Shadow-forwarding evidence is regenerating in CI — <a href={`${REPO_URL}/actions`}>see the runs</a>.
    </p>
  ) : (
    <figure class="shadow">
      <figcaption>
        <strong>Shadow-mode forwarding compliance</strong>
        <span class="meta">
          <span class:list={['pill', data.passed ? 'ok' : 'bad']}>
            {data.passed ? '✓ all checks pass' : '✕ checks failing'}
          </span>{' '}
          · {n(data.config.records)} records/topic → {data.config.realBroker} · verified{' '}
          {fmtVerified(data.generatedAt)} UTC
          {data.gitSha && data.gitSha !== '0000000' ? ` · ${data.gitSha.slice(0, 7)}` : ''}
        </span>
      </figcaption>

      <div class="scroll">
        <table>
          <thead>
            <tr>
              <th>Scenario</th>
              <th class="stat">Result</th>
            </tr>
          </thead>
          <tbody>
            {data.checks.map((c) => (
              <tr>
                <td class="mono">{label(c.name)}</td>
                <td class:list={['cell', c.status]} title={`${c.name}: ${c.status}`}>
                  <span class="sr">{c.status}</span>
                  <span aria-hidden="true">{glyph[c.status]}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <dl class="parity">
        <div>
          <dt>Produced</dt>
          <dd>{n(data.counts.produced)}</dd>
        </div>
        <div>
          <dt>Forwarded → broker</dt>
          <dd>{n(data.counts.forwardedToBroker)}</dd>
        </div>
        <div>
          <dt>Stored locally</dt>
          <dd>{n(data.counts.localStored)}</dd>
        </div>
        <div>
          <dt>Outbox finalized</dt>
          <dd>{n(data.counts.outboxFinalized)}</dd>
        </div>
        <div>
          <dt>Lag</dt>
          <dd>{n(data.counts.lag)}</dd>
        </div>
      </dl>

      <p class="legend">
        <span class="cell pass" aria-hidden="true">✓</span> pass
        <span class="cell fail" aria-hidden="true">✕</span> fail
        <span class="cell na" aria-hidden="true">–</span> n/a (not exercised this run)
      </p>
      <p class="note">
        Each scenario produces to pg_kafka, drives its live forwarding path, then independently consumes
        the real broker to confirm delivery. The parity block is the headline 100% dual-write topic
        (forwarded → broker equals produced). Forwarding throughput is the <em>shadow-async</em> /
        <em>shadow-sync</em> rows in the benchmark table above.
      </p>
    </figure>
  )
}

<style>
  .shadow {
    margin: 1.6rem 0 2.2rem;
  }
  .evidence-pending {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    padding: 1rem 0;
  }
  figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 0.7rem;
  }
  figcaption strong {
    font-size: var(--text-base);
  }
  .meta {
    font-size: var(--text-sm);
    color: var(--fg-muted);
  }
  .pill {
    font-weight: 650;
  }
  .pill.ok {
    color: #1f7a4d;
  }
  .pill.bad {
    color: #c0392b;
  }
  .scroll {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 10px;
  }
  table {
    border-collapse: collapse;
    width: 100%;
    font-size: var(--text-sm);
  }
  th,
  td {
    text-align: left;
    padding: 0.5rem 0.95rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  thead th {
    color: var(--fg-muted);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }
  thead th.stat {
    text-align: center;
  }
  tbody tr:last-child td {
    border-bottom: none;
  }
  .mono {
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .cell {
    text-align: center;
    width: 3rem;
    font-weight: 700;
  }
  .cell.pass {
    color: #1f7a4d;
    background: rgba(31, 122, 77, 0.12);
  }
  .cell.fail {
    color: #c0392b;
    background: rgba(192, 57, 43, 0.14);
  }
  .cell.na {
    color: var(--fg-muted);
    opacity: 0.6;
  }
  .parity {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.6rem;
    margin: 0.9rem 0 0;
    padding: 0;
  }
  .parity div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .parity dt {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
    font-weight: 600;
  }
  .parity dd {
    margin: 0;
    font-variant-numeric: tabular-nums;
    font-weight: 650;
    font-size: var(--text-base);
  }
  .legend {
    margin-top: 0.9rem;
    font-size: var(--text-sm);
    color: var(--fg-muted);
  }
  .legend .cell {
    display: inline-block;
    width: auto;
    border: none;
    padding: 0 0.15rem 0 0.6rem;
    background: none;
  }
  .note {
    margin-top: 0.5rem;
    font-size: var(--text-sm);
    color: var(--fg-muted);
    max-width: var(--measure);
  }
  .sr {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }
  @media (prefers-color-scheme: dark) {
    .cell.pass,
    .pill.ok {
      color: #4ade80;
    }
    .cell.pass {
      background: rgba(74, 222, 128, 0.14);
    }
    .cell.fail,
    .pill.bad {
      color: #f87171;
    }
    .cell.fail {
      background: rgba(248, 113, 113, 0.16);
    }
  }
</style>
