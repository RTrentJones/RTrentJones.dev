---
interface Props {
  href: string;
  title: string;
  date: Date;
  description?: string;
}
const { href, title, date, description } = Astro.props;
const iso = date.toISOString();
---

<article class="post-card">
  <h3><a href={href}>{title}</a></h3>
  <time datetime={iso}>{iso.slice(0, 10)}</time>
  {description && <p>{description}</p>}
</article>

<style>
  .post-card h3 {
    margin: 0 0 0.15rem;
    font-size: var(--text-lg);
  }
  .post-card h3 a {
    color: var(--fg);
    text-decoration: none;
  }
  .post-card h3 a:hover {
    color: var(--accent);
  }
  .post-card p {
    margin: 0.35rem 0 0;
    color: var(--fg-muted);
  }
</style>
