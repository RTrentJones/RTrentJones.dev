---
interface Props {
  siteName: string;
}
const { siteName } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <nav>
    <a href="/rss.xml">RSS</a>
    <a href="https://github.com/RTrentJones">GitHub</a>
  </nav>
  <p class="muted">© {year} {siteName} · built on <a href="https://github.com/RTrentJones/greenlight">Greenlight</a></p>
</footer>

<style>
  .site-footer {
    max-width: var(--measure-wide);
    margin-inline: auto;
    padding: 1.6rem var(--space);
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1.25rem;
  }
  .site-footer nav {
    display: flex;
    gap: 1.1rem;
    font-size: 0.92rem;
  }
  .site-footer p {
    margin: 0;
  }
</style>
