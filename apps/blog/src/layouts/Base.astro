---
import '../styles/tokens.css';
import SiteHeader from '../components/SiteHeader.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  /** Narrow <main> to the reading measure (long-form: posts + project write-ups). */
  prose?: boolean;
  /** Social card image (site-relative or absolute). Defaults to the site card, /og.png. */
  image?: string;
  /** JSON-LD injected as <script type="application/ld+json"> (Person, BlogPosting, …). */
  structuredData?: object | object[];
  /** Keep the page out of search indexes (used by the /v2 draft homepage). */
  noindex?: boolean;
}
const { title, description, prose = false, image, structuredData, noindex = false } = Astro.props;

const SITE_NAME = 'Trent Jones';
const SITE_DESC =
  'Engineer building self-verifying tools. Projects, write-ups, and a blog at rtrentjones.dev.';
const fullTitle = title ? `${title} · ${SITE_NAME}` : SITE_NAME;
const desc = description ?? SITE_DESC;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
// Social card image, resolved to an absolute URL (crawlers require it). Defaults to the site card.
const ogImage = Astro.site ? new URL(image ?? '/og.png', Astro.site).href : (image ?? '/og.png');

// Beta builds get SITE_URL=https://beta.rtrentjones.dev (set by the Greenlight adapter).
const isBeta = Astro.site?.hostname.startsWith('beta.') ?? false;

// Web Analytics (Cloudflare, free + cookieless) is injected automatically at the edge for the
// proxied zone — no app-side beacon. On-account zones only get automatic setup (the manual token
// flow is unavailable), and a second in-app beacon would double-count, so there's deliberately none.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} — blog`} href="/rss.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />

    {
      structuredData && (
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }
  </head>
  <body>
    <SiteHeader siteName={SITE_NAME} isBeta={isBeta} />
    <main class={prose ? 'prose' : ''}>
      <slot />
    </main>
    <Footer siteName={SITE_NAME} />
  </body>
</html>
