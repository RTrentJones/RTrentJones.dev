---
import '../styles/tokens.css';
import SiteHeader from '../components/SiteHeader.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  /** Narrow <main> to the reading measure (long-form: posts + project write-ups). */
  prose?: boolean;
}
const { title, description, prose = false } = Astro.props;

const SITE_NAME = 'Trent Jones';
const SITE_DESC =
  'Engineer building self-verifying tools. Projects, write-ups, and a blog at rtrentjones.dev.';
const fullTitle = title ? `${title} · ${SITE_NAME}` : SITE_NAME;
const desc = description ?? SITE_DESC;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;

// Beta builds get SITE_URL=https://beta.rtrentjones.dev (set by the Greenlight adapter).
const isBeta = Astro.site?.hostname.startsWith('beta.') ?? false;

// Cloudflare Web Analytics (free, privacy-friendly, cookieless). Enable it for rtrentjones.dev in
// the Cloudflare dashboard → Web Analytics, then paste the beacon token below (it's public, not a
// secret). The beacon loads ONLY on the prod apex — never on beta or local.
const CF_BEACON_TOKEN = ''; // ← paste the token to turn analytics on
const analyticsOn = Boolean(CF_BEACON_TOKEN) && Astro.site?.hostname === 'rtrentjones.dev';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} — blog`} href="/rss.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />

    {
      analyticsOn && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${CF_BEACON_TOKEN}"}`}
        />
      )
    }
  </head>
  <body>
    <SiteHeader siteName={SITE_NAME} isBeta={isBeta} />
    <main class={prose ? 'prose' : ''}>
      <slot />
    </main>
    <Footer siteName={SITE_NAME} />
  </body>
</html>
